{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/assets/(.*)", "destination": "/client/assets/$1" },
    { "source": "/favicon.ico", "destination": "/client/favicon.ico" },
    { "source": "/robots.txt", "destination": "/client/robots.txt" },
    { "source": "/(.*)", "destination": "/client/index.html" }
  ]
}
